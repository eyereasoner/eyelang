answer(first, a).
why(
  answer(first, a),
  proof(
    goal(answer(first, a)), by(rule("005_list_deconstruction.pl", clause(3))),
    bindings([binding("X", a)]),
    uses([
      proof(
        goal(first([a, b, c], a)), by(fact("005_list_deconstruction.pl", clause(1))),
        bindings([binding("X", a), binding("_Rest", [b, c])])
      )
    ])
  )
).

answer(tail, [b, c]).
why(
  answer(tail, [b, c]),
  proof(
    goal(answer(tail, [b, c])), by(rule("005_list_deconstruction.pl", clause(4))),
    bindings([binding("Tail", [b, c])]),
    uses([
      proof(
        goal(tail([a, b, c], [b, c])), by(fact("005_list_deconstruction.pl", clause(2))),
        bindings([binding("_Head", a), binding("Tail", [b, c])])
      )
    ])
  )
).

