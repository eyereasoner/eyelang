answer(reachable, b).
why(
  answer(reachable, b),
  proof(
    goal(answer(reachable, b)), by(rule("017_three_step_recursion.pl", clause(6))),
    bindings([binding("X", b)]),
    uses([
      proof(
        goal(path(a, b)), by(rule("017_three_step_recursion.pl", clause(4))),
        bindings([binding("X", a), binding("Y", b)]),
        uses([
          proof(goal(link(a, b)), by(fact("017_three_step_recursion.pl", clause(1))))
        ])
      )
    ])
  )
).

answer(reachable, c).
why(
  answer(reachable, c),
  proof(
    goal(answer(reachable, c)), by(rule("017_three_step_recursion.pl", clause(6))),
    bindings([binding("X", c)]),
    uses([
      proof(
        goal(path(a, c)), by(rule("017_three_step_recursion.pl", clause(5))),
        bindings([binding("X", a), binding("Z", c), binding("Y", b)]),
        uses([
          proof(goal(link(a, b)), by(fact("017_three_step_recursion.pl", clause(1)))),
          proof(
            goal(path(b, c)), by(rule("017_three_step_recursion.pl", clause(4))),
            bindings([binding("X", b), binding("Y", c)]),
            uses([
              proof(goal(link(b, c)), by(fact("017_three_step_recursion.pl", clause(2))))
            ])
          )
        ])
      )
    ])
  )
).

answer(reachable, d).
why(
  answer(reachable, d),
  proof(
    goal(answer(reachable, d)), by(rule("017_three_step_recursion.pl", clause(6))),
    bindings([binding("X", d)]),
    uses([
      proof(
        goal(path(a, d)), by(rule("017_three_step_recursion.pl", clause(5))),
        bindings([binding("X", a), binding("Z", d), binding("Y", b)]),
        uses([
          proof(goal(link(a, b)), by(fact("017_three_step_recursion.pl", clause(1)))),
          proof(
            goal(path(b, d)), by(rule("017_three_step_recursion.pl", clause(5))),
            bindings([binding("X", b), binding("Z", d), binding("Y", c)]),
            uses([
              proof(goal(link(b, c)), by(fact("017_three_step_recursion.pl", clause(2)))),
              proof(
                goal(path(c, d)), by(rule("017_three_step_recursion.pl", clause(4))),
                bindings([binding("X", c), binding("Y", d)]),
                uses([
                  proof(goal(link(c, d)), by(fact("017_three_step_recursion.pl", clause(3))))
                ])
              )
            ])
          )
        ])
      )
    ])
  )
).

