answer(first_key, a).
why(
  answer(first_key, a),
  proof(
    goal(answer(first_key, a)),
    by(rule("020_nested_list_terms.pl", clause(2))),
    bindings([binding("X", a), binding("__anon0", b)]),
    uses([
      proof(
        goal(node([pair(a, b), pair(c, d)])),
        by(fact("020_nested_list_terms.pl", clause(1)))
      )
    ])
  )
).

answer(second_key, c).
why(
  answer(second_key, c),
  proof(
    goal(answer(second_key, c)),
    by(rule("020_nested_list_terms.pl", clause(3))),
    bindings([binding("X", c)]),
    uses([
      proof(
        goal(node([pair(a, b), pair(c, d)])),
        by(fact("020_nested_list_terms.pl", clause(1)))
      )
    ])
  )
).

