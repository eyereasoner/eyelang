answer(first, [x, b, c]).
why(
  answer(first, [x, b, c]),
  proof(
    goal(answer(first, [x, b, c])), by(rule("022_set_nth0_edges.pl", clause(1))),
    bindings([binding("X", [x, b, c])]),
    uses([
      proof(goal(set_nth0(0, [a, b, c], x, [x, b, c])), by(builtin(set_nth0, 4)))
    ])
  )
).

answer(last, [a, b, z]).
why(
  answer(last, [a, b, z]),
  proof(
    goal(answer(last, [a, b, z])), by(rule("022_set_nth0_edges.pl", clause(2))),
    bindings([binding("X", [a, b, z])]),
    uses([
      proof(goal(set_nth0(2, [a, b, c], z, [a, b, z])), by(builtin(set_nth0, 4)))
    ])
  )
).

