answer(atom_concat, eyelog).
why(
  answer(atom_concat, eyelog),
  proof(
    goal(answer(atom_concat, eyelog)),
    by(rule("004_strings_and_atoms.pl", clause(1))),
    bindings([binding("X", eyelog)]),
    uses([
      proof(
        goal(atom_concat(eye, log, eyelog)),
        by(builtin(atom_concat, 3))
      )
    ])
  )
).

answer(str_concat, "eyelog").
why(
  answer(str_concat, "eyelog"),
  proof(
    goal(answer(str_concat, "eyelog")),
    by(rule("004_strings_and_atoms.pl", clause(2))),
    bindings([binding("X", "eyelog")]),
    uses([
      proof(
        goal(str_concat("eye", "log", "eyelog")),
        by(builtin(str_concat, 3))
      )
    ])
  )
).

answer(contains, true).
why(
  answer(contains, true),
  proof(
    goal(answer(contains, true)),
    by(rule("004_strings_and_atoms.pl", clause(3))),
    uses([
      proof(
        goal(contains("eyelog", "log")),
        by(builtin(contains, 2))
      )
    ])
  )
).

answer(not_contains, true).
why(
  answer(not_contains, true),
  proof(
    goal(answer(not_contains, true)),
    by(rule("004_strings_and_atoms.pl", clause(4))),
    uses([
      proof(
        goal(not_contains("eyelog", "cat")),
        by(builtin(not_contains, 2))
      )
    ])
  )
).

