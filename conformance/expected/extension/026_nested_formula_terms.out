answer(binary, exposed(a, name, "A")).
why(
  answer(binary, exposed(a, name, "A")),
  proof(
    goal(answer(binary, exposed(a, name, "A"))),
    by(rule("026_nested_formula_terms.pl", clause(3))),
    bindings([binding("S", a), binding("P", name), binding("O", "A"), binding("F", ((name(a, "A"), knows(a, b)), likes(b, c)))]),
    uses([
      proof(
        goal(formula(((name(a, "A"), knows(a, b)), likes(b, c)))),
        by(fact("026_nested_formula_terms.pl", clause(1)))
      ),
      proof(
        goal(formula_binary(((name(a, "A"), knows(a, b)), likes(b, c)), a, name, "A")),
        by(builtin(formula_binary, 4))
      )
    ])
  )
).

