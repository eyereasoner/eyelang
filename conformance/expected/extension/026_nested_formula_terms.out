answer(atom, name(a, "A")).
why(
  answer(atom, name(a, "A")),
  proof(
    goal(answer(atom, name(a, "A"))),
    by(rule("026_nested_formula_terms.pl", clause(2))),
    bindings([binding("A", name(a, "A")), binding("F", ((name(a, "A"), knows(a, b)), likes(b, c)))]),
    uses([
      proof(
        goal(formula(((name(a, "A"), knows(a, b)), likes(b, c)))),
        by(fact("026_nested_formula_terms.pl", clause(1)))
      ),
      proof(
        goal(formula_atom(((name(a, "A"), knows(a, b)), likes(b, c)), name(a, "A"))),
        by(builtin(formula_atom, 2))
      )
    ])
  )
).

