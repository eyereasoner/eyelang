answer(atom, eyelang).
why(
  answer(atom, eyelang),
  proof(
    goal(answer(atom, eyelang)),
    by(rule("030_string_and_atom_concat.pl", clause(1))),
    bindings([binding("X", eyelang)]),
    uses([
      proof(
        goal(atom_concat(eye, lang, eyelang)),
        by(builtin(atom_concat, 3))
      )
    ])
  )
).

answer(string, "eyelang").
why(
  answer(string, "eyelang"),
  proof(
    goal(answer(string, "eyelang")),
    by(rule("030_string_and_atom_concat.pl", clause(2))),
    bindings([binding("X", "eyelang")]),
    uses([
      proof(
        goal(str_concat("eye", "lang", "eyelang")),
        by(builtin(str_concat, 3))
      )
    ])
  )
).

