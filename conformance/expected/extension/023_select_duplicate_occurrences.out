answer(rest, [b, a]).
why(
  answer(rest, [b, a]),
  proof(
    goal(answer(rest, [b, a])),
    by(rule("023_select_duplicate_occurrences.pl", clause(1))),
    bindings([binding("X", [b, a])]),
    uses([
      proof(
        goal(select(a, [a, b, a], [b, a])),
        by(builtin(select, 3))
      )
    ])
  )
).

answer(rest, [a, b]).
why(
  answer(rest, [a, b]),
  proof(
    goal(answer(rest, [a, b])),
    by(rule("023_select_duplicate_occurrences.pl", clause(1))),
    bindings([binding("X", [a, b])]),
    uses([
      proof(
        goal(select(a, [a, b, a], [a, b])),
        by(builtin(select, 3))
      )
    ])
  )
).

