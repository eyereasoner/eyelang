answer(open, a).
why(
  answer(open, a),
  proof(
    goal(answer(open, a)), by(rule("007_negation_once_generators.pl", clause(4))),
    bindings([binding("X", a)]),
    uses([
      proof(goal(candidate(a)), by(fact("007_negation_once_generators.pl", clause(1)))),
      proof(goal(not(closed(a))), by(builtin(not, 1)))
    ])
  )
).

answer(first_between, 2).
why(
  answer(first_between, 2),
  proof(
    goal(answer(first_between, 2)), by(rule("007_negation_once_generators.pl", clause(5))),
    bindings([binding("X", 2)]),
    uses([
      proof(
        goal(once(between(2, 4, 2))), by(builtin(once, 1)),
        uses([
          proof(goal(between(2, 4, 2)), by(builtin(between, 3)))
        ])
      )
    ])
  )
).

