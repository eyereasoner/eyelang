answer(atom, name(alice, "Alice")).
why(
  answer(atom, name(alice, "Alice")),
  proof(
    goal(answer(atom, name(alice, "Alice"))), by(rule("006_formula_terms.pl", clause(2))),
    bindings([binding("A", name(alice, "Alice")), binding("F", (name(alice, "Alice"), knows(alice, bob)))]),
    uses([
      proof(goal(formula((name(alice, "Alice"), knows(alice, bob)))), by(fact("006_formula_terms.pl", clause(1)))),
      proof(goal(formula_atom((name(alice, "Alice"), knows(alice, bob)), name(alice, "Alice"))), by(builtin(formula_atom, 2)))
    ])
  )
).

