  proof(
    goal(answer(binary, exposed(alice, name, "Alice"))), by(rule("006_formula_terms.pl", clause(3))),
    bindings([binding("S", alice), binding("P", name), binding("O", "Alice"), binding("F", (name(alice, "Alice"), knows(alice, bob)))]),
    uses([
