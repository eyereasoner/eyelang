answer(sum, 5).
why(
  answer(sum, 5),
  proof(
    goal(answer(sum, 5)), by(rule("003_arithmetic_and_comparison.pl", clause(1))),
    bindings([binding("X", 5)]),
    uses([
      proof(goal(add(2, 3, 5)), by(builtin(add, 3)))
    ])
  )
).

