answer(matches, true).
why(
  answer(matches, true),
  proof(
    goal(answer(matches, true)),
    by(rule("011_matching_and_comparison.pl", clause(1))),
    uses([
      proof(
        goal(matches("see", "se")),
        by(builtin(matches, 2))
      )
    ])
  )
).

