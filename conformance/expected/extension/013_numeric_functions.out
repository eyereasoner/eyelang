answer(neg, -5).
why(
  answer(neg, -5),
  proof(
    goal(answer(neg, -5)), by(rule("013_numeric_functions.pl", clause(1))),
    bindings([binding("X", -5)]),
    uses([
      proof(goal(neg(5, -5)), by(builtin(neg, 2)))
    ])
  )
).

answer(abs, 5).
why(
